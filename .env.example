# ==========================================
# example file: .env.example
# ==========================================
# Copy this file to .env and fill it with your values
# DO NOT upload the .env file to Git (it's already in .gitignore)

# ==========================================
# Data Base - PostgreSQL
# ==========================================
DB_URL=jdbc:postgresql://localhost:5432/db_challenge
DB_USERNAME=root
DB_PASSWORD=root
DB_DRIVER=org.postgresql.Driver

# ==========================================
# Data Base Test- PostgreSQL
# ==========================================
DB_TEST_URL=jdbc:postgresql://localhost:5432/challenge_db_test
DB_TEST_USERNAME=root
DB_TEST_PASSWORD=root


# ==========================================
# Server
# ==========================================
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/

# ==========================================
# JPA / Hibernate
# ==========================================
JPA_SHOW_SQL=true
JPA_GENERATE_DDL=true
JPA_HIBERNATE_DDL_AUTO=update

# ==========================================
# Logging
# ==========================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_EXAMPLE=DEBUG


# ==========================================
# Aplicacion
# ==========================================
APP_NAME=Backend-challenge
APP_DESCRIPTION=Backend-challenge
APP_VERSION=1.0.0

